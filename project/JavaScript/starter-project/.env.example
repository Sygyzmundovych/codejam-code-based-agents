# SAP AI Core credentials
# Use one of the following authentication methods:

# Option 1 (Local Development): Paste the full service key JSON as a single line
AICORE_SERVICE_KEY=''

# Option 2 (Cloud Foundry): Credentials are picked up automatically from VCAP_SERVICES binding

# SAP AI Core configuration
RESOURCE_GROUP=ai-agents-codejam

# Model to use (e.g. gpt-4o, claude-3-opus)
MODEL_NAME=gpt-4o

# Grounding pipeline ID (from SAP AI Launchpad > Generative AI Hub > Grounding Management)
GROUNDING_PIPELINE_ID=
